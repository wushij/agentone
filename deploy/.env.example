# Docker Compose 环境变量（复制为 deploy/.env）

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=agentone

# 后端（覆盖 backend/.env 中的连接地址）
DATABASE_URL=mysql+pymysql://root:root@mysql:3306/agentone?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
